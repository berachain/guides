# Snapshot service environment configuration: Bepolia
#
# NOTE: These defaults are intended as a starting point.
# Override host-specific values as needed via SNAPSHOT_CONFIG_FILE.

SNAPSHOT_ENV_NAME="bepolia"

# Runtime paths
SNAPSHOT_DB_PATH="/srv/snapshots/snapshots.db"
SNAPSHOT_ROOT="/srv/snapshots"
SNAPSHOT_PUBLIC_ROOT="/srv/snapshots/public"
SNAPSHOT_TMP_DIR="/var/tmp/snapshots"
SNAPSHOT_INSTALLATIONS_DIR="/srv/chain/installations"
SNAPSHOT_BERABOX_BIN="/opt/berabox/bb"
SNAPSHOT_COSMPRUND_BIN="/opt/cosmprund"
SNAPSHOT_PYTHON_BIN="/usr/bin/python3"

# Scheduler behavior
SNAPSHOT_SAFE_MARGIN_GB="25"
SNAPSHOT_FALLBACK_SIZE_GB="500"
SNAPSHOT_ACTIVE_TYPES="reth-pruned,reth-archive"

# Sync check
SNAPSHOT_PUBLIC_RPC="https://bepolia.rpc.berachain.com"
SNAPSHOT_MAX_BLOCK_LAG="1000000000"

# Public URL/branding
# Must be the canonical public host where index.csv and snapshots are served (used in CSV URLs).
# Loader uses bepolia.snapshots.berachain.com — keep in sync.
SNAPSHOT_PUBLIC_URL_BASE="https://bepolia.snapshots.berachain.com"
SNAPSHOT_SITE_TITLE="Berachain Bepolia Snapshots"
SNAPSHOT_NAV_TITLE="Bepolia Snapshots"
SNAPSHOT_DOCS_URL="https://docs.berachain.com"
SNAPSHOT_LOGO_URL="/logo-white.svg"
