{
  "expo": {
    "name": "EVM Wallet",
    "slug": "wallet-app",
    "version": "1.0.0",
    "scheme": "walletapp",
    "orientation": "portrait",
    "icon": "./walletappicon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "icon": "./walletappicon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.walletapp.dev"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./walletappicon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.walletapp.dev"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
