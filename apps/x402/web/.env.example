# Base URL of the weather-x402 API
VITE_API_BASE_URL=http://localhost:3000

# Thirdweb client id (public) — from https://thirdweb.com/dashboard
# This is the public counterpart of the server's THIRDWEB_SECRET_KEY.
VITE_THIRDWEB_CLIENT_ID=

# 80094 = Berachain mainnet, 80069 = Berachain Bepolia testnet
VITE_CHAIN_ID=80069
