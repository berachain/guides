# Berachain RPC — Bepolia testnet is free on thirdweb's x402 facilitator.
# Switch to mainnet (https://rpc.berachain.com / 80094 / berachain) once you
# have billing enabled on your thirdweb project.
RPC_URL=https://bepolia.rpc.berachain.com
CHAIN_ID=80069
CHAIN_NAME=berachain-bepolia

# Payment config
# HONEY is deployed at the same address on both Berachain mainnet and Bepolia
HONEY_CONTRACT_ADDRESS=0xFCBD14DC51f0A4d49d5E53C2E0950e0bC26d0Dce
HONEY_DECIMALS=18
# Human-readable amount charged per paid request (e.g. 0.1 HONEY)
HONEY_AMOUNT=0.01
# Wallet that receives the HONEY payments
PAY_TO_ADDRESS=

# Thirdweb x402 facilitator
# Get these from https://thirdweb.com/dashboard (Project -> Server Wallets)
# PLEASE NOTE: You need a paid account from Thirdweb to use the x402 facilitator on Berachain Mainnet
THIRDWEB_SECRET_KEY=
# This is needed in order to execute the HONEY transfer from the users wallet
THIRDWEB_SERVER_WALLET_ADDRESS=

PORT=3000
