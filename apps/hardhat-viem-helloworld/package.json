{
  "name": "@berachain/hardhat-viem-helloworld",
  "type": "module",
  "scripts": {
    "build": "./node_modules/.bin/hardhat compile",
    "dev": "tsup --watch",
    "lint": "eslint scripts/ test/ --ext .ts,.tsx --no-ignore",
    "lint:fix": "eslint scripts/ test/ --ext .ts,.tsx --fix --no-ignore",
    "format": "prettier --write \"scripts/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\"",
    "test": "./node_modules/.bin/hardhat test",
    "clean": "rm -rf node_modules; rm -rf .turbo;",
    "compile": "./node_modules/.bin/hardhat compile",
    "node": "./node_modules/.bin/hardhat node",
    "deploy:localhost": "./node_modules/.bin/hardhat run scripts/deploy.ts --network localhost",
    "deploy:berachain": "echo $RPC_URL; ./node_modules/.bin/hardhat run scripts/deploy.ts --network berachainBepolia",
    "verify": "./node_modules/.bin/hardhat verify --network berachainBepolia"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "typescript": "^6.0.0",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.0",
    "@types/node": "^24.0.0",
    "hardhat": "^3.0.0",
    "prettier": "^3.0.0",
    "viem": "^2.7.9"
  },
  "dependencies": {
    "dotenv": "^17.0.0"
  }
}
