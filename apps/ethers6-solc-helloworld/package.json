    "ethers6",
    "solc",
    "solidity",
    "evm"
  ],
  "author": "@codingwithmanny",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.0",
    "dotenv": "^17.0.0",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.7.0"
  },
  "dependencies": {
    "ethers": "^6.9.1",
    "solc": "0.8.35"
  }
